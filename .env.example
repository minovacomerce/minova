# Public site URL — used by the sitemap, canonical tags and OG metadata.
NEXT_PUBLIC_SITE_URL=https://minova-commerce.ch

# Contact form
# Where contact-form submissions are delivered.
CONTACT_FORM_TO=info@minova-commerce.ch

# Transactional email provider (one of Resend / SMTP — leave empty until configured).
RESEND_API_KEY=

# SMTP fallback (only needed if Resend isn't used)
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=

# Optional: rate-limit / bot mitigation backends (production hardening)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
