# Public site URL — used by the sitemap, canonical tags and OG metadata.
NEXT_PUBLIC_SITE_URL=https://minova-commerce.ch

# Contact form — Resend (https://resend.com)
# Required for live email sending; without RESEND_API_KEY the API route
# falls back to a dev-mode log + silent success so local development works.
RESEND_API_KEY=
CONTACT_FORM_TO=info@minova-commerce.ch
CONTACT_FORM_FROM=Minova Commerce <noreply@minova-commerce.ch>

# Optional: rate-limit / bot mitigation backends (production hardening)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
